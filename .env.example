# Copy these into Render → Environment (or a local .env if running locally).
# DO NOT commit your real .env file to git.

# 1. Your MongoDB connection string (REQUIRED)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=ShadowGarden

# 2. Which database name to use inside Mongo (REQUIRED — usually "test")
MONGODB_DB=test

# 3. A long random string. Render can generate this for you automatically.
SESSION_SECRET=change-me-to-a-long-random-string

# 4. Tells the server it is in production mode.
NODE_ENV=production

# 5. (Optional) Render sets PORT for you. Locally use any free port like 3000.
# PORT=3000
